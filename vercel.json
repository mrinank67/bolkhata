{
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/process_voice",
      "dest": "/main.py"
    },
    {
      "src": "/config",
      "dest": "/main.py"
    },
    {
      "src": "/history",
      "dest": "/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}